# StellarPay app URL (the Next.js web app)
STELLARPAY_API_BASE=http://localhost:3000
NEXT_PUBLIC_STELLARPAY_API_BASE=http://localhost:3000

# Your merchant wallet address
MERCHANT_ADDRESS=G...
NEXT_PUBLIC_MERCHANT_ADDRESS=G...

# API key generated from /app/developers in the StellarPay app
STELLARPAY_API_KEY=sp_...

# Webhook signing secret — paste here after running "Register webhook" in step 1
WEBHOOK_SECRET=whsec_...

# Public URL of this test merchant app (used to tell StellarPay where to deliver webhooks)
# For local dev: ngrok / localtunnel / Cloudflare tunnel (must be HTTPS for webhook delivery)
# Or use http://localhost:3001 if running both apps locally and StellarPay can reach it
PUBLIC_URL=http://localhost:3001

# ── Freighter mobile signing (2.5/3.4) — WalletConnect v2 ──
# Free project id from https://cloud.reown.com (WalletConnect Cloud).
# Without it the desktop/browser flows still work; only the
# "pay/subscribe with Freighter mobile" QR buttons are disabled.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Demo catalog (3.1) — fill from `node scripts/seed-test-merchant.mjs` output ──
# The six flows reference pre-provisioned links/plans by id (no runtime lookup),
# like a Stripe merchant hardcoding price ids. Re-run the seed if the DB is reset.
# CHECKOUT_* are numericIds (the /pay page resolves the link by id);
# PLAN_* are on-chain plan ids.
NEXT_PUBLIC_DEMO_CHECKOUT_HOSTED=
NEXT_PUBLIC_DEMO_CHECKOUT_EMBEDDED=
NEXT_PUBLIC_DEMO_CHECKOUT_HEADLESS=
NEXT_PUBLIC_DEMO_PLAN_HOSTED=
NEXT_PUBLIC_DEMO_PLAN_EMBEDDED=
NEXT_PUBLIC_DEMO_PLAN_HEADLESS=
