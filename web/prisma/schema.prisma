generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Merchant {
  address     String   @id          // Stellar address
  displayName String?
  email       String?
  logoUrl     String?
  verified    Boolean  @default(false)  // stub — no real KYC for MVP
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PaymentLink {
  id          String   @id @default(cuid())
  extId       String   @unique  // plink_ + ULID — external API/dashboard handle (3.2)
  numericId   String   @unique  // Snowflake u64 — the canonical link id (URL param + contract link_id)
  merchant    String            // Stellar address
  amount      String            // stroops as string
  productName String   @default("Untitled product or service")
  description String?
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  events      Event[]
}

model Plan {
  id            String         @id @default(cuid())
  extId         String         @unique  // plan_ + ULID — external API/dashboard handle (3.2)
  onChainId     String         @unique  // u64 as string returned from create_plan
  merchant      String
  amount        String
  productName   String         @default("Untitled product or service")
  description   String?
  interval      Int                     // min_interval_secs — the on-chain cadence floor
  intervalLabel String
  intervalUnit  String         @default("month")  // minute | day | week | month | year
  intervalCount Int            @default(1)
  archivedAt    DateTime?
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
}

model Subscription {
  id            String   @id @default(cuid())
  extId         String   @unique  // sub_ + ULID — external API/dashboard handle (3.2)
  onChainId     String   @unique  // u64 as string returned from subscribe
  planOnChainId String
  plan          Plan     @relation(fields: [planOnChainId], references: [onChainId])
  subscriber    String
  merchant      String
  amount        String
  payerName     String?
  payerEmail    String?
  status        String   @default("Active")  // Active | PastDue | Canceled
  retryCount    Int      @default(0)         // consecutive insufficient-BALANCE observations (2j retry policy); never incremented by allowance shortfalls (2.4a)
  nextRetryAt   DateTime?                    // when the retry cron should re-attempt this charge
  needsReauthorization Boolean @default(false)  // 2.4b: allowance exhausted/expired but balance OK — contract lost permission; funded, so NOT canceled. Self-clears on next successful charge
  reauthRequestedAt    DateTime?              // when the sub first entered needs-reauthorization (for dunning grace timing, 2.4f)
  anchorAt      DateTime @default(now())     // subscribe date; billing boundaries are computed from this (2.1)
  periodsCharged Int     @default(1)         // charges made so far; next_charge_at = billingDateAfter(anchorAt, interval, periodsCharged)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  events        Event[]
}

model WebhookEndpoint {
  id        String   @id @default(cuid())
  merchant  String
  url       String
  secret    String   // whsec_ + 32 hex — HMAC-SHA256 signing secret, shown once on creation
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model ApiKey {
  id         String    @id @default(cuid())
  merchant   String
  name       String?
  keyHash    String    @unique  // SHA-256 of the raw key — never stored in plaintext
  prefix     String             // "sp_" + first 8 chars, shown in the UI
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?
}

model Event {
  id             String       @id @default(cuid())
  extId          String       @unique  // evt_ + ULID — external/webhook event id (3.2)
  type           String       // payment.settled | subscription.created | subscription.charged | subscription.canceled
  txHash         String       @unique
  paymentLinkId  String?
  subscriptionId String?
  paymentLink    PaymentLink? @relation(fields: [paymentLinkId], references: [id])
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  data           Json
  createdAt      DateTime     @default(now())
}
